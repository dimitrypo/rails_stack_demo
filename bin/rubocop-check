#!/usr/bin/env bash

# RuboCop runner script for Docker environment
# Usage: ./bin/rubocop-check [--fix]

set -e

if [ "$1" = "--fix" ] || [ "$1" = "-a" ]; then
    echo "🔧 Running RuboCop with auto-correction..."
    docker-compose exec web bundle exec rubocop --autocorrect-all
elif [ "$1" = "--safe-fix" ] || [ "$1" = "-A" ]; then
    echo "🔧 Running RuboCop with safe auto-correction..."
    docker-compose exec web bundle exec rubocop --autocorrect
else
    echo "🔍 Running RuboCop..."
    docker-compose exec web bundle exec rubocop
fi

echo "✅ RuboCop finished!"
