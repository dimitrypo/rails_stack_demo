<% if params[:from] == 'show' %>
	<turbo-stream action="replace" target="page-content">
		<template>
			<%= render partial: 'articles/index', formats: [:html], locals: { articles: Article.recent.page(params[:page]) } %>
		</template>
	</turbo-stream>
<% else %>
	<turbo-stream action="remove" target="<%= dom_id(@article) %>"></turbo-stream>
<% end %>