<%= turbo_frame_tag dom_id(article) do %>
  <article class="bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow duration-200 p-6 my-5">
    <div class="flex justify-between items-start">
      <div class="flex-1">
        <div class="flex items-center space-x-1 mb-2">
          <% unless article.published? %>
            <span class="px-2 py-1 mr-2 text-xs font-semibold text-yellow-800 bg-yellow-100 rounded-full">Draft</span>
          <% end %>
          <span class="text-sm text-gray-500">
            By <%= article.author.email.split('@').first %>
          </span>
          <span class="text-sm text-gray-500">
            <%= time_ago_in_words(article.published_at || article.created_at) %> ago
          </span>
        </div>

        <h2 class="text-xl font-semibold text-gray-900 mb-2">
          <%= link_to article.title, article_path(article), 
                      class: "hover:text-blue-600 transition-colors",
                      data: { turbo_frame: "_top" } %>
        </h2>

        <p class="text-gray-600 line-clamp-3 mb-4">
          <%= truncate(article.content, length: 200) %>
        </p>

        <div class="flex items-center space-x-4">
          <%= link_to "Read more →", article_path(article), 
                      class: "text-blue-600 hover:text-blue-800 font-medium text-sm",
                      data: { turbo_frame: "_top" } %>

          <% if user_signed_in? && article.author == current_user %>
            <%= link_to "Edit", edit_article_path(article), 
                        class: "text-gray-600 hover:text-gray-800 text-sm",
                        data: { turbo_frame: "_top" } %>
            <%= link_to "Delete", article_path(article), 
                        data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                        class: "text-red-600 hover:text-red-800 text-sm" %>
          <% end %>
        </div>
      </div>
    </div>
  </article>
<% end %>
