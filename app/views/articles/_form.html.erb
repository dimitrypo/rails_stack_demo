<%= form_with(model: article, local: false) do |form| %>
  <% if article.errors.any? %>
    <div class="mb-6 bg-red-50 border border-red-200 rounded-lg p-4">
      <h3 class="text-sm font-medium text-red-800 mb-2">
        <%= pluralize(article.errors.count, "error") %> prohibited this article from being saved:
      </h3>
      <ul class="list-disc list-inside text-sm text-red-700">
        <% article.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-6">
    <div>
      <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :title, 
                          class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500",
                          placeholder: "Enter article title" %>
    </div>

    <div>
      <%= form.label :content, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_area :content, 
                         rows: 10,
                         class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500",
                         placeholder: "Write your article content here..." %>
    </div>

    <div class="flex items-center">
      <%= form.check_box :published, 
                         class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
      <%= form.label :published, "Publish article", 
                     class: "ml-2 block text-sm text-gray-700" %>
      <span class="ml-2 text-xs text-gray-500">(Uncheck to save as draft)</span>
    </div>

    <div class="flex justify-end space-x-3 pt-4">
      <%= link_to "Cancel", 
                  article.persisted? ? article_path(article) : articles_path,
                  class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50",
                  data: { turbo_frame: "_top" } %>
      <%= form.submit article.persisted? ? "Update Article" : "Create Article", 
                      class: "px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 cursor-pointer" %>
    </div>
  </div>
<% end %>